---
import JournalLayout from "../layouts/JournalLayout.astro";
import { getPublishedPosts, longDate, postHref } from "../lib/posts";

const posts = await getPublishedPosts();

// Oldest-first rank for stable "№ 001…" numbering.
const oldestFirst = [...posts].reverse();
const rankById = new Map<string, number>();
oldestFirst.forEach((p, i) => rankById.set(p.id, i + 1));

// Build the Project (tag) index.
//   Tags are treated as "projects" — the primary classification axis.
//   Count posts per tag, sort by count desc then alpha.
const tagCounts = new Map<string, number>();
posts.forEach((p) => {
  p.data.tags.forEach((t) => {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  });
});
const projects = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));
---
<JournalLayout
  title="Archive — HANBIN"
  description="전체 아카이브 — published essays from HANBIN · A Journal."
  issue={`All ${posts.length} Essays`}
  essayCount={posts.length}
>
  <section class="archive" id="archive">
    <div class="container">
      <div class="section-head">
        <h2><span class="num">§</span>The Archive</h2>
        <div class="rule"></div>
        <div class="count archive-count">{posts.length} entries</div>
      </div>

      {projects.length > 0 && (
        <div class="project-filter" id="project-filter">
          <div class="filter-label">Filter by project</div>
          <div class="chip-row">
            <button type="button" class="chip active" data-tag="">
              All <span class="count">{posts.length}</span>
            </button>
            {projects.map(({ tag, count }) => (
              <button type="button" class="chip" data-tag={tag}>
                {tag} <span class="count">{count}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      <div class="archive-list">
        {posts.map((p) => (
          <a class="archive-row" href={postHref(p)} data-tags={p.data.tags.join(",")}>
            <span class="idx">№ {String(rankById.get(p.id) ?? 0).padStart(3, "0")}</span>
            <span class="date">{longDate(p.data.date)}</span>
            <span class="title" set:html={p.data.title}></span>
            <span class="cat">{p.data.category}</span>
            <span class="read">{p.data.readtime ?? ""}</span>
          </a>
        ))}
      </div>

      <p class="archive-empty" id="archive-empty" hidden>
        해당 프로젝트에 속하는 글이 아직 없습니다.
      </p>
    </div>
  </section>
</JournalLayout>

<script>
  /**
   * Client-side Project filter.
   * ------------------------------------------------------------------
   * Each archive row carries `data-tags="a,b,c"`. Clicking a chip hides
   * rows whose tags don't include the chosen one. "All" (empty tag) resets.
   * Pure vanilla JS — no framework, no hydration cost.
   */
  (() => {
    const rows = Array.from(document.querySelectorAll<HTMLElement>(".archive-row"));
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".chip"));
    const counter = document.querySelector<HTMLElement>(".archive-count");
    const empty = document.querySelector<HTMLElement>("#archive-empty");

    function apply(tag: string) {
      let visible = 0;
      rows.forEach((row) => {
        const tags = (row.dataset.tags || "").split(",").filter(Boolean);
        const show = !tag || tags.includes(tag);
        row.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (counter) {
        counter.textContent = `${visible} ${visible === 1 ? "entry" : "entries"}`;
      }
      if (empty) empty.hidden = visible !== 0;
      chips.forEach((c) => c.classList.toggle("active", c.dataset.tag === tag));
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => apply(chip.dataset.tag || ""));
    });

    // Deep link: /archive?tag=slam-research preselects that project.
    // We match case-insensitively and ignore unknown tags gracefully.
    const params = new URLSearchParams(window.location.search);
    const requested = (params.get("tag") || "").toLowerCase();
    if (requested) {
      const match = chips.find(
        (c) => (c.dataset.tag || "").toLowerCase() === requested,
      );
      if (match) {
        apply(match.dataset.tag || "");
        // Pull the filter into view without a hard jump.
        document
          .getElementById("project-filter")
          ?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
  })();
</script>
