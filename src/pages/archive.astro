---
import JournalLayout from "../layouts/JournalLayout.astro";
import {
  getPublishedPosts,
  buildRankById,
  longDate,
  postHref,
  postNumber,
  plural,
} from "../lib/posts";
import { CATEGORIES } from "../content/categories";

const posts = await getPublishedPosts();
const rankById = buildRankById(posts);

// Build the Project (tag) index.
//   Tags are treated as "projects" — the primary classification axis.
//   Count posts per tag, sort by count desc then alpha.
const tagCounts = new Map<string, number>();
posts.forEach((p) => {
  p.data.tags.forEach((t) => {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  });
});
const projects = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag, count]) => ({ tag, count }));

// Build the Category (genre) index.
//   Categories are a closed enum (see content/config.ts). We render the
//   chip row in the canonical schema order so the UI is stable even when
//   some categories happen to have zero posts at the moment.
const categoryCounts = new Map<string, number>();
posts.forEach((p) => {
  const c = p.data.category;
  categoryCounts.set(c, (categoryCounts.get(c) ?? 0) + 1);
});
const categories = CATEGORIES.map((c) => ({
  category: c,
  count: categoryCounts.get(c) ?? 0,
}));
---
<JournalLayout
  title="Archive — HANBIN"
  description="전체 아카이브 — published essays from HANBIN · A Journal."
  issue={`All ${plural(posts.length, "Essay")}`}
  essayCount={posts.length}
>
  <section class="archive" id="archive">
    <div class="container">
      <div class="section-head">
        <h2><span class="num">§</span>The Archive</h2>
        <div class="rule"></div>
        <div class="count archive-count">{plural(posts.length, "entry", "entries")}</div>
      </div>

      {projects.length > 0 && (
        <div class="project-filter" id="project-filter">
          <div class="filter-label" id="filter-project-label">Filter by project</div>
          <div class="chip-row" role="group" aria-labelledby="filter-project-label" data-filter-axis="tag">
            <button type="button" class="chip active" aria-pressed="true" data-tag="">
              All <span class="count">{posts.length}</span>
            </button>
            {projects.map(({ tag, count }) => (
              <button type="button" class="chip" aria-pressed="false" data-tag={tag}>
                {tag} <span class="count">{count}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      <div class="category-filter" id="category-filter">
        <div class="filter-label" id="filter-category-label">Filter by category</div>
        <div class="chip-row" role="group" aria-labelledby="filter-category-label" data-filter-axis="category">
          <button type="button" class="chip active" aria-pressed="true" data-category="">
            All <span class="count">{posts.length}</span>
          </button>
          {categories.map(({ category, count }) => (
            <button type="button" class="chip" aria-pressed="false" data-category={category}>
              {category} <span class="count">{count}</span>
            </button>
          ))}
        </div>
        {/*
          Reset button — explicit "back to All / All" so users don't have
          to click two chips to undo a deep-linked filter. Hidden by
          default; the filter script reveals it whenever any axis is
          active.
        */}
        <button type="button" id="filter-reset" class="filter-reset" hidden>
          Reset filters
        </button>
      </div>

      <div class="archive-list">
        {posts.map((p) => (
          <a
            class="archive-row"
            href={postHref(p)}
            data-tags={JSON.stringify(p.data.tags)}
            data-category={p.data.category}
          >
            <span class="idx">{postNumber(p, rankById.get(p.id) ?? 0)}</span>
            <span class="date">{longDate(p.data.date)}</span>
            <span class="title" set:html={p.data.title}></span>
            <span class="cat">{p.data.category}</span>
            <span class="read">{p.data.readtime ?? ""}</span>
          </a>
        ))}
      </div>

      <p class="archive-empty" id="archive-empty" hidden>
        해당 조건에 맞는 글이 아직 없습니다.
      </p>
    </div>
  </section>
</JournalLayout>

<script>
  /**
   * Client-side filter — two axes (Project + Category), AND-combined.
   * ------------------------------------------------------------------
   * Each archive row carries:
   *   - data-tags="[...]"   JSON-encoded array of project tags
   *   - data-category="..." (genre; exactly one)
   *
   * Why JSON for tags? The previous comma-joined form silently broke
   * if a tag contained a comma. The schema now refuses commas in tags
   * too, but JSON keeps the on-the-wire format unambiguous regardless.
   *
   * State is one selected value per axis. Empty string = "All". A row
   * shows only when BOTH axes match (AND).
   *
   * Deep links: `/archive?tag=…&category=…` pre-applies both filters.
   * Chip clicks now also write back to the URL via history.replaceState
   * so the address bar always reflects the visible state — sharable
   * filter links without a navigation event.
   *
   * Pure vanilla JS — no framework, no hydration cost.
   */
  (() => {
    type Chip = HTMLButtonElement;

    const rows = Array.from(document.querySelectorAll<HTMLElement>(".archive-row"));
    const counter = document.querySelector<HTMLElement>(".archive-count");
    const empty = document.querySelector<HTMLElement>("#archive-empty");
    const reset = document.querySelector<HTMLButtonElement>("#filter-reset");

    const tagChips = Array.from(
      document.querySelectorAll<Chip>('[data-filter-axis="tag"] .chip'),
    );
    const categoryChips = Array.from(
      document.querySelectorAll<Chip>('[data-filter-axis="category"] .chip'),
    );

    // Pre-parse tag arrays once (vs every apply()). Bad JSON falls
    // back to []; a malformed attribute shouldn't take down the page.
    const rowTags = new Map<HTMLElement, string[]>();
    rows.forEach((row) => {
      try {
        const parsed = JSON.parse(row.dataset.tags || "[]");
        rowTags.set(row, Array.isArray(parsed) ? parsed : []);
      } catch {
        rowTags.set(row, []);
      }
    });

    let activeTag = "";
    let activeCategory = "";

    function apply(updateUrl = true) {
      let visible = 0;
      rows.forEach((row) => {
        const tags = rowTags.get(row) || [];
        const category = row.dataset.category || "";
        const tagOk = !activeTag || tags.includes(activeTag);
        const catOk = !activeCategory || category === activeCategory;
        const show = tagOk && catOk;
        row.classList.toggle("is-hidden", !show);
        if (show) visible++;
      });
      if (counter) {
        counter.textContent = `${visible} ${visible === 1 ? "entry" : "entries"}`;
      }
      if (empty) empty.hidden = visible !== 0;

      const setPressed = (chip: Chip, key: "tag" | "category", active: string) => {
        const matches = (chip.dataset[key] || "") === active;
        chip.classList.toggle("active", matches);
        chip.setAttribute("aria-pressed", matches ? "true" : "false");
      };
      tagChips.forEach((c) => setPressed(c, "tag", activeTag));
      categoryChips.forEach((c) => setPressed(c, "category", activeCategory));

      if (reset) reset.hidden = !activeTag && !activeCategory;

      if (updateUrl) {
        const params = new URLSearchParams();
        if (activeTag) params.set("tag", activeTag);
        if (activeCategory) params.set("category", activeCategory);
        const qs = params.toString();
        const next = qs ? `?${qs}` : window.location.pathname;
        history.replaceState(null, "", next);
      }
    }

    tagChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        activeTag = chip.dataset.tag || "";
        apply();
      });
    });
    categoryChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        activeCategory = chip.dataset.category || "";
        apply();
      });
    });
    reset?.addEventListener("click", () => {
      activeTag = "";
      activeCategory = "";
      apply();
    });

    // Deep link: read both URL params, find matching chips (case-
    // insensitive lookup; the canonical value comes from the chip's
    // dataset so capitalization stays consistent).
    const params = new URLSearchParams(window.location.search);
    const reqTag = (params.get("tag") || "").toLowerCase();
    const reqCat = (params.get("category") || "").toLowerCase();

    if (reqTag) {
      const match = tagChips.find(
        (c) => (c.dataset.tag || "").toLowerCase() === reqTag,
      );
      if (match) activeTag = match.dataset.tag || "";
    }
    if (reqCat) {
      const match = categoryChips.find(
        (c) => (c.dataset.category || "").toLowerCase() === reqCat,
      );
      if (match) activeCategory = match.dataset.category || "";
    }
    // Always apply once on load — populates aria-pressed and the
    // counter from the canonical (possibly-empty) state. Skip the URL
    // rewrite on this initial pass: if we landed here from a deep
    // link we want to *honor* the URL, not echo it back.
    apply(/* updateUrl */ false);
  })();
</script>
