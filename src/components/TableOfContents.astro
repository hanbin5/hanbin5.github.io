---
/**
 * TableOfContents — magazine-style margin annotation for posts.
 *
 * Visual language:
 *   The site's section heads use a small mono number kicker ("01 — ")
 *   alongside a serif title. The TOC borrows the exact same pattern:
 *   small muted mono index, serif title, fine and quiet. h3 entries
 *   drop the number (they're sub-sections of the parent h2) and shift
 *   right with a small italic dash, the way classical print TOCs
 *   express subordinate entries.
 *
 * Layout language:
 *   The article stays *exactly* where it has always been — perfectly
 *   centered in the page chrome. The rail is absolutely positioned
 *   inside <main> (which is set position:relative in newsprint.css),
 *   so it occupies the right gutter without disturbing the article's
 *   centering. The inner <nav> uses position:sticky so it pins while
 *   the reader scrolls, and naturally stops at the bottom of <main>
 *   (i.e., never overlaps the dark footer).
 *
 * Behaviour:
 *   1. Walk h2/h3 inside <article class="prose">.
 *   2. Auto-id any heading missing one (slugified, deduped).
 *   3. Number h2 entries 01, 02, ... in render order.
 *   4. Track the heading nearest the top of the reading area and
 *      highlight that row (text colour + accent dot).
 *   5. Hide the rail entirely when there are zero headings.
 */
---
<aside class="toc-rail" aria-label="Table of contents" data-toc-empty>
  <nav class="toc">
    <p class="toc-label">목차</p>
    <ol class="toc-list"></ol>
  </nav>
</aside>

<script>
  const init = () => {
    const article = document.querySelector("article.prose");
    const wrap = document.querySelector<HTMLElement>(".toc-rail");
    const list = document.querySelector<HTMLOListElement>(".toc-list");
    if (!article || !wrap || !list) return;

    list.innerHTML = "";

    // We scan h1/h2/h3 inside article.prose. The post title's h1
    // sits in <header class="post-header"> *outside* the article,
    // so it's never picked up. Authors who write `#` for section
    // headings (Obsidian default) see those used as top-level TOC
    // entries; authors who write `##` get them as second-level.
    const headings = Array.from(
      article.querySelectorAll<HTMLHeadingElement>("h1, h2, h3"),
    );
    if (headings.length === 0) {
      wrap.style.display = "none";
      return;
    }
    wrap.removeAttribute("data-toc-empty");
    wrap.style.display = "";

    const slugify = (text: string) => {
      const base = text
        .normalize("NFKD")
        .replace(/[̀-ͯ]/g, "")
        .toLowerCase()
        .replace(/[^\p{Letter}\p{Number}\s-]+/gu, "")
        .trim()
        .replace(/\s+/g, "-");
      return base || "section";
    };

    type Item = { id: string; link: HTMLAnchorElement; el: HTMLHeadingElement };
    const items: Item[] = [];
    const used = new Set<string>();
    let h2Index = 0;

    for (const h of headings) {
      let id = h.id;
      if (!id) {
        const base = slugify(h.textContent || "");
        let candidate = base;
        let n = 2;
        while (used.has(candidate) || document.getElementById(candidate)) {
          candidate = `${base}-${n++}`;
        }
        h.id = candidate;
        id = candidate;
      }
      used.add(id);

      const tag = h.tagName.toLowerCase();
      // Both h1 and h2 are treated as top-level entries (numbered);
      // h3 is the subordinate level (em-dash instead of a number).
      // We tag h1 as `toc-h2` in CSS terms so we don't have to
      // duplicate the styles.
      const isTop = tag === "h1" || tag === "h2";
      const li = document.createElement("li");
      li.className = `toc-item ${isTop ? "toc-h2" : "toc-h3"}`;

      const a = document.createElement("a");
      a.href = `#${id}`;

      if (isTop) {
        h2Index += 1;
        const num = document.createElement("span");
        num.className = "toc-num";
        num.textContent = String(h2Index).padStart(2, "0");
        a.appendChild(num);
      } else {
        const dash = document.createElement("span");
        dash.className = "toc-dash";
        dash.textContent = "—";
        dash.setAttribute("aria-hidden", "true");
        a.appendChild(dash);
      }

      const label = document.createElement("span");
      label.className = "toc-text";
      label.textContent = h.textContent || "";
      a.appendChild(label);

      li.appendChild(a);
      list.appendChild(li);
      items.push({ id, link: a, el: h });
    }

    // Active-section tracking — last heading whose top has crossed
    // the "reading line" just below the topbar.
    const READING_LINE = 120;
    let activeLink: HTMLAnchorElement | null = null;

    const update = () => {
      let chosen: Item | null = null;
      for (const it of items) {
        const top = it.el.getBoundingClientRect().top;
        if (top - READING_LINE <= 0) chosen = it;
        else break;
      }
      if (!chosen) chosen = items[0];
      if (chosen.link === activeLink) return;
      if (activeLink) activeLink.classList.remove("active");
      chosen.link.classList.add("active");
      activeLink = chosen.link;
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    update();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style is:global>
  /* Scoped-to-class rather than scoped-by-Astro: elements inside the
     TOC list are created at runtime by the script above (document.
     createElement). Astro's scoped-CSS attribute is only applied to
     template-declared elements, so dynamic children would otherwise
     miss every selector here. The class names are unique to this
     component, so going global doesn't risk collisions. */

  /* The rail is parked in the right gutter of <main>. main is set to
     position:relative in newsprint.css; this is absolute against it,
     so it doesn't disturb the article's centered column. */
  .toc-rail {
    position: absolute;
    top: 64px;          /* aligned with .post-header padding-top */
    bottom: 0;
    right: max(28px, calc((100vw - var(--container-max)) / 2 + var(--container-pad)));
    width: 200px;
    pointer-events: none;
  }
  /* The inner nav re-enables interactions and sticks while we scroll
     within <main>. Once we reach the footer, sticky stops naturally. */
  .toc-rail .toc {
    position: sticky;
    top: 110px;
    pointer-events: auto;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
    /* Quiet scrollbar — only visible on hover. */
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
  }
  .toc-rail .toc:hover { scrollbar-color: var(--line-soft) transparent; }
  .toc-rail .toc::-webkit-scrollbar { width: 4px; }
  .toc-rail .toc::-webkit-scrollbar-thumb { background: transparent; border-radius: 2px; }
  .toc-rail .toc:hover::-webkit-scrollbar-thumb { background: var(--line-soft); }
  .toc-rail[data-toc-empty] { display: none; }

  /* Mono kicker — same language as the rest of the site's labels. */
  .toc-label {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--muted);
    margin: 0 0 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line-soft);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: none;
  }

  .toc-item { margin: 0; }
  .toc-item + .toc-item { margin-top: 10px; }

  /* Each row is `<a>` containing a small mono index/dash and a serif
     title. We use grid so the title aligns regardless of whether
     the leading mark is two digits or an em-dash. */
  .toc-item a {
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: baseline;
    gap: 8px;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.15s ease;
  }
  .toc-item a:hover { color: var(--ink); }

  .toc-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--accent-bright);
    /* Stick the number to the baseline of the title's first line. */
    line-height: 1.6;
    transition: color 0.15s ease;
  }

  .toc-dash {
    font-family: var(--serif);
    font-size: 13px;
    color: var(--muted);
    text-align: right;
    line-height: 1.55;
  }

  .toc-text {
    font-family: var(--serif);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.005em;
    /* Wrap long headings cleanly across two lines instead of
       ellipsizing — long Korean section titles read better wrapped. */
    overflow-wrap: anywhere;
  }

  /* h3 entries: smaller, italic, deeper indent so they read as
     children of the h2 above them. */
  .toc-h3 a {
    grid-template-columns: 22px 1fr;
    padding-left: 14px;
  }
  .toc-h3 .toc-text {
    font-size: 12.5px;
    font-style: italic;
    color: var(--muted);
  }

  /* Active row — colour-only signal (no border bar). The mono index
     also gains the brand accent so the active row reads as a unit. */
  .toc-item a.active .toc-text { color: var(--accent); font-weight: 500; }
  .toc-item a.active .toc-num  { color: var(--accent); }
  .toc-item a.active .toc-dash { color: var(--accent); }

  /* Hide the rail below 1100px — there isn't enough gutter to host
     a 200px column without crowding the article. */
  @media (max-width: 1099px) {
    .toc-rail { display: none !important; }
  }
</style>
