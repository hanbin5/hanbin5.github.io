---
/**
 * TableOfContents — magazine-style margin annotation for posts.
 *
 * Hierarchy:
 *   h1 → top level: small mono number ("01", "02", ...) + serif title.
 *   h2 → second level: indented one step, dot marker, smaller text.
 *   h3 → third level: indented two steps, em-dash marker, italic.
 *   The three levels are visually distinct so a post that mixes
 *   `#`, `##`, `###` reads as a proper outline.
 *
 * Layout:
 *   The article stays exactly where it has always been — perfectly
 *   centered in the page chrome. The rail is absolutely positioned
 *   inside <main> (which is set position:relative in newsprint.css),
 *   so it occupies the right gutter without disturbing the article's
 *   centering. The inner <nav> uses position:sticky so it pins while
 *   the reader scrolls; once we reach the footer, sticky stops
 *   naturally — no overlap with the dark band.
 *
 * Behavior:
 *   1. Walk h1/h2/h3 inside <article class="prose">. The post-title
 *      h1 lives outside .prose so it isn't picked up.
 *   2. Auto-id any heading missing one (slug + dedupe).
 *   3. Number h1 entries 01, 02, ... in order.
 *   4. Track the heading nearest the top of the reading area and
 *      highlight that row.
 *   5. Hide the rail entirely when there are zero headings.
 */
---
<aside class="toc-rail" aria-label="Table of contents" data-toc-empty>
  <nav class="toc">
    <p class="toc-label">Contents</p>
    <ol class="toc-list"></ol>
  </nav>
</aside>

<script>
  const init = () => {
    const article = document.querySelector("article.prose");
    const wrap = document.querySelector<HTMLElement>(".toc-rail");
    const list = document.querySelector<HTMLOListElement>(".toc-list");
    if (!article || !wrap || !list) return;

    list.innerHTML = "";

    const headings = Array.from(
      article.querySelectorAll<HTMLHeadingElement>("h1, h2, h3"),
    );
    if (headings.length === 0) {
      wrap.style.display = "none";
      return;
    }
    wrap.removeAttribute("data-toc-empty");
    wrap.style.display = "";

    const slugify = (text: string) => {
      const base = text
        .normalize("NFKD")
        .replace(/[̀-ͯ]/g, "")
        .toLowerCase()
        .replace(/[^\p{Letter}\p{Number}\s-]+/gu, "")
        .trim()
        .replace(/\s+/g, "-");
      return base || "section";
    };

    type Item = { id: string; link: HTMLAnchorElement; el: HTMLHeadingElement };
    const items: Item[] = [];
    const used = new Set<string>();
    let h1Index = 0;

    for (const h of headings) {
      let id = h.id;
      if (!id) {
        const base = slugify(h.textContent || "");
        let candidate = base;
        let n = 2;
        while (used.has(candidate) || document.getElementById(candidate)) {
          candidate = `${base}-${n++}`;
        }
        h.id = candidate;
        id = candidate;
      }
      used.add(id);

      const tag = h.tagName.toLowerCase();
      const li = document.createElement("li");
      li.className = `toc-item toc-${tag}`;

      const a = document.createElement("a");
      a.href = `#${id}`;

      // Leading mark: number for h1, dot for h2, em-dash for h3.
      // All three levels share the same 22px-wide mark column so the
      // titles align in a clean vertical line regardless of level.
      const mark = document.createElement("span");
      if (tag === "h1") {
        h1Index += 1;
        mark.className = "toc-num";
        mark.textContent = String(h1Index).padStart(2, "0");
      } else if (tag === "h2") {
        mark.className = "toc-marker toc-marker-dot";
        mark.textContent = "·";
        mark.setAttribute("aria-hidden", "true");
      } else {
        mark.className = "toc-marker toc-marker-dash";
        mark.textContent = "—";
        mark.setAttribute("aria-hidden", "true");
      }
      a.appendChild(mark);

      const label = document.createElement("span");
      label.className = "toc-text";
      label.textContent = h.textContent || "";
      a.appendChild(label);

      li.appendChild(a);
      list.appendChild(li);
      items.push({ id, link: a, el: h });
    }

    // Active-section tracking: last heading whose top has crossed
    // the "reading line" just below the topbar.
    const READING_LINE = 120;
    let activeLink: HTMLAnchorElement | null = null;

    const update = () => {
      let chosen: Item | null = null;
      for (const it of items) {
        const top = it.el.getBoundingClientRect().top;
        if (top - READING_LINE <= 0) chosen = it;
        else break;
      }
      if (!chosen) chosen = items[0];
      if (chosen.link === activeLink) return;
      if (activeLink) activeLink.classList.remove("active");
      chosen.link.classList.add("active");
      activeLink = chosen.link;
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    update();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style is:global>
  /* Why is:global — the script creates the <li>/<a>/<span> rows at
     runtime via document.createElement(). Astro's scoped-CSS
     attribute is only stamped onto template-declared elements, so
     scoped selectors would miss every dynamic child. The class
     names are unique to this component, so going global is safe. */

  .toc-rail {
    position: absolute;
    top: 64px;          /* aligned with .post-header padding-top */
    bottom: 0;
    width: 200px;
    /* Anchor the rail to the prose column rather than to the page
       chrome. .prose renders at ~800px wide (68ch in Lora), centered
       in the viewport, so its right edge sits at viewport-center +
       400px. We park the TOC's left edge at viewport-center + 460px
       to keep a clean ~60px breathing zone between body content and
       the rail no matter how wide the window is. (Computed via
       `right`: 100vw - (50vw + 460 + 200) = 50vw - 660.) */
    right: calc(50vw - 660px);
    pointer-events: none;
  }
  .toc-rail .toc {
    position: sticky;
    top: 110px;
    pointer-events: auto;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
  }
  .toc-rail .toc:hover { scrollbar-color: var(--line-soft) transparent; }
  .toc-rail .toc::-webkit-scrollbar { width: 4px; }
  .toc-rail .toc::-webkit-scrollbar-thumb { background: transparent; border-radius: 2px; }
  .toc-rail .toc:hover::-webkit-scrollbar-thumb { background: var(--line-soft); }
  .toc-rail[data-toc-empty] { display: none; }

  /* Mono kicker. No border-bottom — earlier we had a thin rule
     here, but at common viewport widths it lined up vertically with
     the prose h2 border-bottom in the article column, making them
     read as a single very long line crossing the page. Whitespace
     alone separates the label from the entries cleanly. */
  .toc-label {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--muted);
    margin: 0 0 18px;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: none;
  }
  .toc-item { margin: 0; }
  .toc-item + .toc-item { margin-top: 8px; }

  /* Each row is `<a><span mark/><span text/></a>`. We grid the row
     so titles always align on a fixed mark column, regardless of
     whether the mark is a 2-digit number or a single dot. */
  .toc-item a {
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: baseline;
    gap: 10px;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.15s ease;
  }
  .toc-item a:hover { color: var(--ink); }

  .toc-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--accent-bright);
    line-height: 1.55;
    transition: color 0.15s ease;
  }
  .toc-marker {
    font-family: var(--serif);
    color: var(--line-soft);
    text-align: right;
    line-height: 1.55;
  }
  .toc-marker-dot  { font-size: 16px; }
  .toc-marker-dash { font-size: 12px; }

  .toc-text {
    font-family: var(--serif);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.005em;
    overflow-wrap: anywhere;
  }

  /* === Three hierarchy levels === */

  /* h1: top level — numbered, full-size title, no extra indent. */
  .toc-h1 .toc-text { font-size: 14px; color: var(--ink); }

  /* h2: second level — indented one step, smaller, muted. */
  .toc-h2 a { padding-left: 16px; }
  .toc-h2 .toc-text { font-size: 13px; color: var(--muted); }

  /* h3: third level — indented two steps, italic, smaller still. */
  .toc-h3 a { padding-left: 32px; }
  .toc-h3 .toc-text { font-size: 12.5px; font-style: italic; color: var(--muted); }

  /* Active row — colour-only, applied to all three levels. */
  .toc-item a.active .toc-text   { color: var(--accent); font-weight: 500; }
  .toc-item a.active .toc-num    { color: var(--accent); }
  .toc-item a.active .toc-marker { color: var(--accent); }

  /* Hide the rail below 1340px. The prose column is 68ch ≈ 800px,
     and we want at least a 60px gap before the 200px rail plus a
     small viewport-edge margin — that needs ≈ 1320px of horizontal
     space minimum. Below this, the article goes back to its normal
     no-rail layout. */
  @media (max-width: 1339px) {
    .toc-rail { display: none !important; }
  }
</style>
