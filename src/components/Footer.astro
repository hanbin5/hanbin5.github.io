---
/**
 * Footer — royal-blue colophon with brand, sections, elsewhere, subscribe.
 */
const year = new Date().getFullYear();
---
<footer>
  <div class="container">
    <div>
      <div class="brand-f">HANBIN</div>
      <p class="about-f">
        A personal journal published irregularly from Seoul. Typeset in Fraunces
        &amp; Inter. Made with patience, coffee, and occasional doubt.
      </p>
    </div>
    <div>
      <h5>Sections</h5>
      <ul>
        <li><a href="/archive">Archive</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </div>
    <div>
      <h5>Elsewhere</h5>
      <ul>
        <li><a href="https://github.com/hanbin5">GitHub</a></li>
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </div>
    <div>
      <h5>Subscribe</h5>
      <ul>
        <li><a href="mailto:hanbinftr55@gmail.com">Email the Editor</a></li>
      </ul>
    </div>
  </div>
  <div class="container fine">
    <span>© {year} Hanbin · All rights reserved</span>
    <span>Set in type, one essay at a time.</span>
  </div>
</footer>
