---
/**
 * TopBar — the thin strip at the very top.
 *   [HANBIN]   Friday · April 24, 2026 · Seoul          [nav links]
 * Brand lives here so individual post pages don't need a second brand
 * block underneath. Date is computed at build time.
 */
const today = new Date();
const weekday = today.toLocaleDateString("en-US", { weekday: "long" });
const month = today.toLocaleDateString("en-US", { month: "long" });
const day = today.getDate();
const year = today.getFullYear();
const dateLabel = `${weekday} · ${month} ${day}, ${year} · Seoul`;
---
<div class="topbar">
  <div class="container">
    <a class="brand" href="/">HANBIN</a>
    <div class="date">{dateLabel}</div>
    <div class="nav">
      <a class="nav-archive" href="/archive">Archive</a>
      <a class="nav-about" href="/about">About</a>
      <a class="nav-contact" href="mailto:hanbinftr55@gmail.com">Contact</a>
    </div>
  </div>
</div>
