---
/**
 * Longform — the two-column feature section (essay + Departments sidebar).
 * Body paragraphs come in via <slot>; sidebar items via the `depts` prop.
 */
export interface DeptItem {
  date: string;
  title: string;
}
export interface Props {
  kicker?: string;
  title: string;
  depts?: DeptItem[];
}
const {
  kicker = "§ 02 · The Longform",
  title,
  depts = [],
} = Astro.props;
---
<section class="two-col" id="longform">
  <div class="longform">
    <div class="kicker">{kicker}</div>
    <h3 set:html={title}></h3>
    <slot />
  </div>

  <aside class="dept">
    <h4>Departments</h4>
    {depts.map((d) => (
      <div class="dept-item">
        <div class="d-date">{d.date}</div>
        <div class="d-title">{d.title}</div>
      </div>
    ))}
  </aside>
</section>
