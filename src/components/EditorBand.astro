---
/**
 * EditorBand — the gray pullquote band under the hero.
 */
export interface Props {
  quote?: string;
  attrib?: string;
}
const {
  quote = "Ever tried. Ever failed. No matter. Try again. Fail again. Fail better.",
  attrib = "— Samuel Beckett",
} = Astro.props;
---
<section class="band">
  <div class="container">
    <div class="label">Editor's Note</div>
    <div>
      <div class="pullquote">{quote}</div>
      <div class="attrib">{attrib}</div>
    </div>
  </div>
</section>
