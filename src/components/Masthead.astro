---
/**
 * Masthead — the giant "HANBIN" nameplate, with motto on the left and
 * issue number / founding info on the right.
 *
 * `issue` and `essayCount` are intentionally undefined-by-default. An
 * empty journal should read as empty, not as a fake "Vol. II · No. 04
 * — 12 Essays." The caller passes the real numbers; if it doesn't, we
 * just omit those lines rather than lie.
 */
import { plural } from "../lib/posts";

export interface Props {
  motto?: string;
  issue?: string;
  since?: string;
  essayCount?: number;
}
const {
  motto = "A quiet journal on\ntools, attention,\nand making things.",
  issue,
  since = "Est. 2024",
  essayCount,
} = Astro.props;
---
<div class="masthead">
  <div class="container">
    <div class="motto" set:html={motto.replace(/\n/g, "<br/>")} />
    <h1><a href="/">HANBIN</a></h1>
    <div class="issue">
      {issue && <strong>{issue}</strong>}
      {since}<br/>
      {typeof essayCount === "number" && plural(essayCount, "Essay") + " to Date"}
    </div>
  </div>
</div>
<div class="tagline">" 정리 중인 생각을 위한 작은 공간 "</div>
